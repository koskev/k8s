      GitHub environment name where secrets will be synced. Required when secrets_location is set to 'environment'.
    ||| } },
    withEnvironmentName(value):: self {
      resource+: {
        vault_secrets_sync_gh_destination+: { [terraformName]+: { environment_name: value } },
