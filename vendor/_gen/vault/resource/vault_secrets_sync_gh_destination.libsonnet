{
  new(terraformName, name):: {
    _type:: 'tf',
    resource+: {
      vault_secrets_sync_gh_destination+: { [terraformName]+: {
        name: name,
      } },
    },
    '#withAccessToken':: { 'function': { help: |||
      Fine-grained or personal access token. 
    ||| } },
    withAccessToken(value):: self {
      resource+: {
        vault_secrets_sync_gh_destination+: { [terraformName]+: { access_token: value } },
      },
    },
    '#withAllowedIpv4Addresses':: { 'function': { help: |||
      List of allowed IPv4 addresses in CIDR notation (e.g., 192.168.1.1/32) for outbound connections from Vault to the destination. If not set, all IPv4 addresses are allowed. 
    ||| } },
    withAllowedIpv4Addresses(value):: self {
      resource+: {
        vault_secrets_sync_gh_destination+: { [terraformName]+: { allowed_ipv4_addresses: value } },
      },
    },
    '#withAllowedIpv6Addresses':: { 'function': { help: |||
      List of allowed IPv6 addresses in CIDR notation (e.g., 2001:db8::1/128) for outbound connections from Vault to the destination. If not set, all IPv6 addresses are allowed. 
    ||| } },
    withAllowedIpv6Addresses(value):: self {
      resource+: {
        vault_secrets_sync_gh_destination+: { [terraformName]+: { allowed_ipv6_addresses: value } },
      },
    },
    '#withAllowedPorts':: { 'function': { help: |||
      List of allowed ports for outbound connections from Vault to the destination. If not set, all ports are allowed. 
    ||| } },
    withAllowedPorts(value):: self {
      resource+: {
        vault_secrets_sync_gh_destination+: { [terraformName]+: { allowed_ports: value } },
      },
    },
    '#withAppName':: { 'function': { help: |||
      The user-defined name of the GitHub App configuration. 
    ||| } },
    withAppName(value):: self {
      resource+: {
        vault_secrets_sync_gh_destination+: { [terraformName]+: { app_name: value } },
      },
    },
    '#withDisableStrictNetworking':: { 'function': { help: |||
      If set to true, disables strict networking enforcement for this destination. When disabled, Vault will not enforce allowed IP addresses and ports. 
    ||| } },
    withDisableStrictNetworking(value):: self {
      resource+: {
        vault_secrets_sync_gh_destination+: { [terraformName]+: { disable_strict_networking: value } },
      },
    },
    '#withEnvironmentName':: { 'function': { help: |||
      GitHub environment name where secrets will be synced. Required when secrets_location is set to 'environment'. 
    ||| } },
    withEnvironmentName(value):: self {
      resource+: {
        vault_secrets_sync_gh_destination+: { [terraformName]+: { environment_name: value } },
      },
    },
    '#withGranularity':: { 'function': { help: |||
      Determines what level of information is synced as a distinct resource at the destination. Can be 'secret-path' or 'secret-key' 
    ||| } },
    withGranularity(value):: self {
      resource+: {
        vault_secrets_sync_gh_destination+: { [terraformName]+: { granularity: value } },
      },
    },
    withId(value):: self {
      resource+: {
        vault_secrets_sync_gh_destination+: { [terraformName]+: { id: value } },
      },
    },
    '#withInstallationId':: { 'function': { help: |||
      The ID of the installation generated by GitHub when the app referenced by the app_name was installed in the user's GitHub account. Necessary if the app_name field is also provided. 
    ||| } },
    withInstallationId(value):: self {
      resource+: {
        vault_secrets_sync_gh_destination+: { [terraformName]+: { installation_id: value } },
      },
    },
    '#withName':: { 'function': { help: |||
      Unique name of the github destination. 
    ||| } },
    withName(value):: self {
      resource+: {
        vault_secrets_sync_gh_destination+: { [terraformName]+: { name: value } },
      },
    },
    '#withNamespace':: { 'function': { help: |||
      Target namespace. (requires Enterprise) 
    ||| } },
    withNamespace(value):: self {
      resource+: {
        vault_secrets_sync_gh_destination+: { [terraformName]+: { namespace: value } },
      },
    },
    '#withRepositoryName':: { 'function': { help: |||
      Name of the repository. 
    ||| } },
    withRepositoryName(value):: self {
      resource+: {
        vault_secrets_sync_gh_destination+: { [terraformName]+: { repository_name: value } },
      },
    },
    '#withRepositoryOwner':: { 'function': { help: |||
      GitHub organization or username that owns the repository. 
    ||| } },
    withRepositoryOwner(value):: self {
      resource+: {
        vault_secrets_sync_gh_destination+: { [terraformName]+: { repository_owner: value } },
      },
    },
    '#withSecretNameTemplate':: { 'function': { help: |||
      Template describing how to generate external secret names. 
    ||| } },
    withSecretNameTemplate(value):: self {
      resource+: {
        vault_secrets_sync_gh_destination+: { [terraformName]+: { secret_name_template: value } },
      },
    },
    '#withSecretsLocation':: { 'function': { help: |||
      Determines where secrets will be stored in GitHub. Valid values are 'repository' or 'environment'. 
    ||| } },
    withSecretsLocation(value):: self {
      resource+: {
        vault_secrets_sync_gh_destination+: { [terraformName]+: { secrets_location: value } },
      },
    },
    '#withType':: { 'function': { help: |||
      Type of secrets destination. 
    ||| } },
    withType(value):: self {
      resource+: {
        vault_secrets_sync_gh_destination+: { [terraformName]+: { type: value } },
      },
    },
  },
}
